{
  "expo": {
    "name": "Aether Vault",
    "slug": "aether-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.herdoydev.neondrift"
    },
    "android": {
      "package": "com.herdoydev.neondrift",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7106488480723857~9905002683",
          "iosAppId": "ca-app-pub-7106488480723857~9905002683"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0b55c4f6-d9f0-4818-bf6a-9bbd768d1fea"
      }
    },
    "owner": "herdoycode"
  }
